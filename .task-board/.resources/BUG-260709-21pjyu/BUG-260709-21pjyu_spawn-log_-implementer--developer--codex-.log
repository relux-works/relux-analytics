import Foundation
import ReluxAnalytics
import Testing
@testable import ReluxAnalyticsAppMetrica

@Suite("AppMetrica analytics service")
struct AppMetricaServiceTests {
    @Test func serviceStartsAppMetricaOnlyOnceAndForwardsIdentity() async {
        let client = RecordingAppMetricaClient()
        let service = Analytics.AppMetricaService(apiKey: "sample-key", client: client)
        let identity = Analytics.Identity(
            userID: "user-1",
            properties: [
                "source": .string("sample"),
                "count": .int(3),
                "ratio": .double(0.75),
                "premium": .bool(false)
            ]
        )

        await service.start()
        await service.start()
        await service.identify(identity)
        await service.resetIdentity()

        #expect(await client.activationAPIKeys == ["sample-key"])
        #expect(await client.userProfileIDs == ["user-1", nil])
        #expect(
            await client.events == [
                .init(
                    name: "analytics_identified",
                    parameters: [
                        "source": .string("sample"),
                        "count": .int(3),
                        "ratio": .double(0.75),
                        "premium": .bool(false)
                    ]
                )
            ]
        )
    }

    @Test func serviceMapsInstantCollectorEventToAppMetricaEvent() async {
        let client = RecordingAppMetricaClient()
        let service = Analytics.AppMetricaService(apiKey: "sample-key", client: client)
        let event = Analytics.InstantEvent(
            name: "sample_instant_tapped",
            parameters: [
                "screen": .string("main"),
                "count": .int(2)
            ]
        )

        await service.track(.instant(event))

        #expect(await client.activationAPIKeys == ["sample-key"])
        #expect(
            await client.events == [
                .init(
                    name: "sample_instant_tapped",
                    parameters: [
                        "screen": .string("main"),
                        "count": .int(2),
                        "event_family": .string("instant")
                    ]
                )
            ]
        )
    }

    @Test func serviceFlushesEventsBufferWhenConfigured() async {
        let client = RecordingAppMetricaClient()
        let service = Analytics.AppMetricaService(
            apiKey: "sample-key",
            client: client,
            eventsBufferFlushPolicy: .afterEveryReport
        )
        let event = Analytics.InstantEvent(
            name: "sample_instant_tapped",
            parameters: ["screen": .string("main")]
        )

        await service.track(.instant(event))

        #expect(await client.events.count == 1)
        #expect(await client.eventsBufferFlushCount == 1)
    }

    @Test func serviceMapsContinuousAggregateToFinishEvent() async throws {
        let client = RecordingAppMetricaClient()
        let manager = Analytics.DefaultContinuousEventManager()
        let service = Analytics.AppMetricaService(
            apiKey: "sample-key",
            client: client,
            continuousEventManager: manager
        )
        let spanID = Analytics.SpanID("sample-span")
        let start = Date(timeIntervalSince1970: 100)

        await service.start()
        await service.track(
            .continuous(
                .start(
                    .init(
                        name: "sample_session_started",
                        finishEventName: "sample_session_stopped",
                        spanID: spanID,
                        timestamp: start,
                        staleTimeout: 30,
                        parameters: ["screen": .string("main")]
                    )
                )
            )
        )
        await service.track(
            .continuous(
                .update(
                    .init(
                        spanID: spanID,
                        timestamp: start.addingTimeInterval(2),
                        parameters: ["phase": .string("latest_update")]
                    )
                )
            )
        )
        await service.track(
            .continuous(
                .stop(
                    .init(
                        name: "sample_session_stopped",
                        spanID: spanID,
                        timestamp: start.addingTimeInterval(5),
                        reason: .completed,
                        parameters: ["result": .string("done")]
                    )
                )
            )
        )

        try await waitUntil {
            await client.events.count == 1
        }

        #expect(
            await client.events == [
                .init(
                    name: "sample_session_stopped",
                    parameters: [
                        "event_family": .string("continuous"),
                        "span_id": .string("sample-span"),
                        "start_event_name": .string("sample_session_started"),
                        "finish_event_name": .string("sample_session_stopped"),
                        "continuous_state": .string("fired"),
                        "close_reason": .string("completed"),
                        "duration_ms": .int(5000),
                        "stale_timeout_ms": .int(30000),
                        "start.screen": .string("main"),
                        "latest.phase": .string("latest_update"),
                        "finish.result": .string("done")
                    ]
                )
            ]
        )
    }
}

private actor RecordingAppMetricaClient: Analytics.AppMetricaClient {
    struct Event: Equatable, Sendable {
        let name: String
        let parameters: Analytics.AppMetricaParameters
    }

    private(set) var activationAPIKeys: [String] = []
    private(set) var userProfileIDs: [String?] = []
    private(set) var events: [Event] = []
    private(set) var eventsBufferFlushCount = 0

    func activate(apiKey: String) async -> Bool {
        activationAPIKeys.append(apiKey)
        return true
    }

    func setUserProfileID(_ userID: String?) async {
        userProfileIDs.append(userID)
    }

    func reportEvent(
        name: String,
        parameters: Analytics.AppMetricaParameters
    ) async {
        events.append(.init(name: name, parameters: parameters))
    }

    func sendEventsBuffer() async {
        eventsBufferFlushCount += 1
    }
}

private func waitUntil(
    timeout: Duration = .seconds(1),
    _ predicate: () async -> Bool
) async throws {
    let deadline = ContinuousClock.now + timeout

    while ContinuousClock.now < deadline {
        if await predicate() {
            return
        }
        try await Task.sleep(for: .milliseconds(10))
    }

    Issue.record("Timed out waiting for condition")
}

